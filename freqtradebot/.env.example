# Freqtrade Environment Variables
# Format: FREQTRADE__SECTION__KEY (note the double underscores)

# Exchange API Credentials
FREQTRADE__EXCHANGE__KEY=your_bingx_api_key
FREQTRADE__EXCHANGE__SECRET=your_bingx_api_secret

# Telegram Bot
FREQTRADE__TELEGRAM__TOKEN=your_telegram_token
FREQTRADE__TELEGRAM__CHAT_ID=your_chat_id
