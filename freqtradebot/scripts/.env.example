# AI Trading System - Configuration
# Copy this to .env and fill in your actual values

# ═══════════════════════════════════════════════════════════
# REMOTE DEPLOYMENT (DigitalOcean Droplet)
# ═══════════════════════════════════════════════════════════

# Your DigitalOcean droplet IP address
DROPLET_IP=your.droplet.ip.address

# SSH key path (used to connect to droplet)
SSH_KEY_PATH=~/.ssh/id_do

# SSH user (usually 'root' for DigitalOcean)
SSH_USER=root

# Remote path where freqtradebot is installed
REMOTE_PATH=~/freqtradebot

# Docker service name (from docker-compose.yml)
DOCKER_SERVICE=freqtrade-live

# ═══════════════════════════════════════════════════════════
# OPTIONAL: Anthropic API (if not using Claude Code scheduler)
# ═══════════════════════════════════════════════════════════

# Only needed if you want to use API instead of Claude Code
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ═══════════════════════════════════════════════════════════
# OPTIONAL: Advanced sentiment/on-chain data (Phase 2+)
# ═══════════════════════════════════════════════════════════

# LUNARCRUSH_API_KEY=your_lunarcrush_key
# GLASSNODE_API_KEY=your_glassnode_key
# COINGLASS_API_KEY=your_coinglass_key
# TWITTER_BEARER_TOKEN=your_twitter_token
