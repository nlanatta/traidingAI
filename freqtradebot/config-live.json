{
  "max_open_trades": 3,
  "stake_currency": "USDT",
  "stake_amount": 10,
  "tradable_balance_ratio": 0.99,
  "fiat_display_currency": "USD",

  "_comment_dry_run": "IMPORTANT: Keep dry_run=true to test with real API keys safely. Only change to false when ready for REAL TRADING with REAL MONEY",
  "dry_run": true,

  "cancel_open_orders_on_exit": false,

  "user_data_dir": "/freqtrade/user_data",
  "strategy_path": "/freqtrade/strategies",

  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },

  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },

  "exit_pricing":{
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },

  "_comment_exchange": "API keys loaded from FREQTRADE__EXCHANGE__KEY and FREQTRADE__EXCHANGE__SECRET env vars",
  "exchange": {
    "name": "bingx",
    "ccxt_config": {},
    "ccxt_async_config": {},
    "pair_whitelist": [
      "BTC/USDT",
      "ETH/USDT",
      "SOL/USDT",
      "ADA/USDT",
      "DOT/USDT",
      "LINK/USDT"
    ],
    "pair_blacklist": []
  },

  "pairlists": [
    {"method": "StaticPairList"}
  ],

  "edge": {
    "enabled": false
  },

  "_comment_telegram": "Placeholders below are overridden by FREQTRADE__TELEGRAM__TOKEN and FREQTRADE__TELEGRAM__CHAT_ID env vars",
  "telegram": {
    "enabled": true,
    "token": "placeholder_will_be_overridden_by_env",
    "chat_id": "placeholder_will_be_overridden_by_env"
  },

  "api_server": {
    "enabled": false,
    "listen_ip_address": "127.0.0.1",
    "listen_port": 8080,
    "username": "freqtrader",
    "password": "placeholder-password",
    "jwt_secret_key": "somethingRandomSomethingRandom123"
  },

  "bot_name": "freqtrade_live",
  "initial_state": "running",
  "force_entry_enable": false,
  "internals": {
    "process_throttle_secs": 5
  }
}
